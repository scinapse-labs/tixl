    },
    {
      "Id": "e5a7649f-684e-4938-8ae3-7289f5b9ff45"/*B*/,
      "DefaultValue": 0.0
    },
    {
      "Id": "e77660e2-0fd0-45ea-8e0b-c607a757bb49"/*Points*/,
      "DefaultValue": null
    },
    {
      "Id": "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df"/*ShaderCode*/,
      "DefaultValue": "// f - normalized position in buffer\n// p - current point defined as SourcePoints[idx]\n\nfloat t= Biased( frac((f * (B+1) + A)) );\nfloat3 pForward = qRotateVec3(float3(0,0,1), p.Rotation);\n\np.Position += pForward * (t -0.5);\np.Color = SampleGradient(t);\np.Scale += t;"
    },
    {
