      },
      "ParameterSetsForChildIds": {
        "00000000-0000-0000-0000-000000000000": {
          "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df": "int2 ip= int2(idx % 256, idx / 256);\n\n//float4 smp= Image.Load(int3(ip.xy,0));\nfloat4 c = Image.SampleLevel(ClampedSampler, float2(ip.xy) / 256.0, 0);\n\np.Position = c.rgb-0.5;\np.Color=c;",
          "2a0cf45c-bcf5-4802-b32b-84cef0f1c129": 65536
        }
