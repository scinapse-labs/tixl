          "a5c7863e-9c26-4109-9851-3244086b0ccc": 1.73,
          "e5a7649f-684e-4938-8ae3-7289f5b9ff45": -3.1,
          "b909844f-cff7-4907-9bc8-e9c2281582bf": 0.45,
          "20226539-a481-4df6-8dc7-cc65de915ea9": 50.0,
          "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df": "//move points position\np.Position += Offset;\n\n//move points on Y for sine wave\np.Position.y += sin(6*f * A+B + Time)*C;\n\n// color every point\np.Color = float4(1,1,0,1); \n\n// control a specific point\nif(idx == (int)D){\n  p.FX1 = 5.0;\n  p.Color = float4(1,0,1,1);\n}"
