    {
      "Id": "b1c26ee7-a46d-49a0-bdba-a6d81f117ec3",
      "IsPreset": true,
      "ActivationIndex": 2,
      "Title": "Knot",
      "PosOnCanvas": {
        "X": 163.0,
        "Y": 122.55056
      },
      "ParameterSetsForChildIds": {
        "00000000-0000-0000-0000-000000000000": {
          "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df": "float3 pos=float3(0,0,1);\npos=Generator(f);\np.Position = pos;\nfloat3 up=float3(0,-1,0);\nfloat3 fwd=normalize(Generator(f-.01)-Generator(f+.01));\np.Rotation=qLookAt(fwd,up);\n",
          "a5c7863e-9c26-4109-9851-3244086b0ccc": 1.0,
          "e5a7649f-684e-4938-8ae3-7289f5b9ff45": 2.52,
          "b909844f-cff7-4907-9bc8-e9c2281582bf": 7.0,
          "20226539-a481-4df6-8dc7-cc65de915ea9": 2.0,
          "864dfe5a-14f2-490f-be9c-ee13ad58605c": "float3 Generator(float f){\n\nfloat3 v=(f*A+B)*float3(C,D,1);\n    float3 p=float3(0,0,0.2);\n    p=qRotateVec3(p,qFromAngleAxis(PI*2*v.x,float3(1,0,0)));\n    p.z+=1;\n    p=qRotateVec3(p,qFromAngleAxis(PI*2*v.y,float3(0,1,0)));\n    //p*=0.25;p.x+=1;\n    //p=qRotateVec3(p,qFromAngleAxis(PI*2*v.z,float3(0,0,1)));\n//p*=exp2(.15*sin(f*23.2));\n    return p;\n}",
          "2a0cf45c-bcf5-4802-b32b-84cef0f1c129": 1000
        }
      }
    },
    {
      "Id": "0d2fbfe5-dc58-4516-8b74-f7f0af5e8eca",
      "IsPreset": true,
      "ActivationIndex": 4,
      "Title": "Another Knot",
      "PosOnCanvas": {
        "X": 0.0,
        "Y": 122.55056
      },
      "ParameterSetsForChildIds": {
        "00000000-0000-0000-0000-000000000000": {
          "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df": "float3 pos=float3(0,0,1);\npos=Generator(f);\np.Position = pos;\nfloat3 up=float3(0,-1,0);\nfloat3 fwd=normalize(Generator(f-.01)-Generator(f+.01));\np.Rotation=qLookAt(fwd,up);\n",
          "a5c7863e-9c26-4109-9851-3244086b0ccc": 0.84,
          "e5a7649f-684e-4938-8ae3-7289f5b9ff45": 2.52,
          "864dfe5a-14f2-490f-be9c-ee13ad58605c": "float3 Generator(float f){\n\nfloat3 v=(f*A+B)*float3(3,5,7);\n    float3 p=float3(0,0,1);\n    p=qRotateVec3(p,qFromAngleAxis(PI*2*v.x,float3(1,0,0)));\n    p=qRotateVec3(p,qFromAngleAxis(PI*2*v.y,float3(0,1,0)));\n    p=qRotateVec3(p,qFromAngleAxis(PI*2*v.z,float3(0,0,1)));\np*=exp2(.15*sin(f*23.2));\n    return p;\n}",
          "2a0cf45c-bcf5-4802-b32b-84cef0f1c129": 1000
        }
      }
    },
    {
      "Id": "64612b56-770a-4671-9b16-02e708a0c9c4",
      "IsPreset": true,
      "ActivationIndex": 7,
      "Title": "Visualize Image Colors",
      "PosOnCanvas": {
        "X": 0.0,
