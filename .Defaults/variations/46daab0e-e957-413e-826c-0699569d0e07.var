          },
          "8c3ffefe-8721-4dde-b252-22eb8be02d3f": "// A simple color grading using the gradient\n\nc= ImageA.Sample(Sampler, uv);\n\nc = float4(\n  Biased(Gradient.SampleLevel( ClampedSampler, float2(c.r, 0.5),0).r),\n  Biased(Gradient.SampleLevel( ClampedSampler, float2(c.g, 0.5),0).g),\n  Biased(Gradient.SampleLevel( ClampedSampler, float2(c.b, 0.5),0).b),\n  Biased(Gradient.SampleLevel( ClampedSampler, float2(c.a, 0.5),0).a)\n);\n"
        }
