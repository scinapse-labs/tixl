          "3d84725a-594b-46d8-aa21-eec99026115d": 0.35,
          "b4914d9d-7a39-46e1-8b45-803e1449039a": {
            "X": 0.43500006,
            "Y": 0.735
          },
          "8c3ffefe-8721-4dde-b252-22eb8be02d3f": "// Simple Displacement\n// Connect two images and use Offset Parameter\n\nfloat4 cb= ImageB.Sample(Sampler, uv  );\nfloat d= ApplyGainAndBias(cb.r, GainAndBias);\nc= ImageA.Sample(Sampler, uv - d * Offset * float2(1,-1));"
        }
      }
    },
